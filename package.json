{
  "name": "localground",
  "version": "3.0.2",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "npm run build -w packages/core && npm run build -w packages/mcp && npm run build -w packages/cli",
    "build:check": "tsc --noEmit -p packages/core/tsconfig.json && tsc --noEmit -p packages/mcp/tsconfig.json && tsc --noEmit -p packages/cli/tsconfig.json && tsc --noEmit -p tsconfig.test.json",
    "pretest": "npm run build",
    "test": "vitest run",
    "verify:tarball": "node scripts/verify-tarball.mjs",
    "clean": "npm run clean --workspaces --if-present"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "tsup": "^8.5.1",
    "typescript": "~5.7",
    "vitest": "^3.2.6"
  },
  "overrides": {
    "@modelcontextprotocol/sdk": {
      "fast-uri": "3.1.2",
      "hono": "4.12.25",
      "ip-address": "10.2.0",
      "qs": "6.15.2",
      "express-rate-limit": "8.5.2"
    },
    "postcss": "8.5.15"
  }
}
